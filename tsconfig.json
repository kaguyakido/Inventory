{
    "compilerOptions": {
    "target": "ES2020",       
    "module": "ESNext",      
    "lib": ["ES2020", "DOM"],  
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
    "node_modules",
    "dist"
  ]
}